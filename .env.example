# Copy to .env.local and fill in. Never commit .env.local.

# --- Supabase (required) ---
# Project URL + anon key: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, never exposed to the browser
SUPABASE_SERVICE_ROLE_KEY=

# --- WhatsApp Cloud API (optional — bot features) ---
# A string you choose; must match the token entered in Meta webhook setup
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0

# --- Anthropic (optional — WhatsApp intent parser) ---
ANTHROPIC_API_KEY=
